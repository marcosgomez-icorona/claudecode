  {
    "id": "3bec08cbe9d96c31",
    "type": "function",
    "z": "1d06854d91e05168",
    "name": "function 80",
    "func": "let entrada1 = msg.payload.veloc1; // This will pick up the value of 100 from the Inject node\nlet entrada2 = msg.payload.presionaire;\nlet entrada3 = msg.payload.presionvapor;\nlet entrada4 = msg.payload.presionagua;\nlet entrada5 = msg.payload.contbolsas;\nlet reporte = \"\";\n\nreporte = reporte + \"<break time='0.25s'/> por favor espere <break time='0.5s'/> su solicitud esta en proceso\";\nreporte = reporte + \"<break time='0.25s'/> En Trapiche la velocidad del primer molino es de <break time='0.25s'/>\" + entrada1 + \"rpm\";\nreporte = reporte + \"<break time='0.25s'/> la presión de aire es de <break time='0.25s'/>\" + entrada2 + \"bar\";\nreporte = reporte + \"<break time='0.25s'/> En caldera la presión de vapor es de <break time='0.25s'/>\" + entrada3 + \"bar\";\nreporte = reporte + \"<break time='0.25s'/> la presión de agua de alimentación es de <break time='0.25s'/>\" + entrada4 + \"bar\";\nreporte = reporte + \"<break time='0.25s'/> En salon la cantidad de bolsas de azucar es de <break time='0.25s'/>\" + entrada5 + \"unidades\";\nreporte = reporte + \"<break time='0.5s'/> es hora de una taza de cafe  <break time='0.25s'/> que tengas un buen dia\";\n\nmsg.payload = reporte;\nreturn msg;",
