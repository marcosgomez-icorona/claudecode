    "func": "const chatId = \"-4293484523\";\nconst ffmpegPath = 'C:\\\\ffmpeg\\\\bin\\\\ffmpeg.exe';\nconst basePath = 'C:\\\\Videos\\\\moega';\n\nconst d = new Date();\nconst pad = n => String(n).padStart(2,'0');\nconst ts = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}_${pad(d.getHours())}-${pad(d.getMinutes())}-${pad(d.getSeconds())}`;\n\nconst filename = `camara_${ts}.mp4`;\nconst fullpath = `${basePath}\\\\${filename}`;\n\nmsg.chatId = chatId;\nmsg.filename = filename;\nmsg.fullpath = fullpath;\n\n// RTSP principal\nmsg.rtsp = \"rtsp://admin:corona1234@192.168.3.60:554/cam/realmonitor?channel=1&subtype=0\";\n\n// MP4 liviano y compatible con Telegram\nmsg.payload = `\"${ffmpegPath}\" -y -rtsp_transport tcp -i \"${msg.rtsp}\" -t 40 -an -vf scale=1280:-2 -r 15 -c:v libx264 -preset veryfast -pix_fmt yuv420p -b:v 1200k -maxrate 1200k -bufsize 2400k -movflags +faststart \"${msg.fullpath}\"`;\n\nreturn msg;",
