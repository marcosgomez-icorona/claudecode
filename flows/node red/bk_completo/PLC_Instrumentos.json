    "query": "WITH unicos AS (\r\n    SELECT\r\n        id_movimiento,\r\n        patente,\r\n        chofer,\r\n        neto_cana,\r\n        CONVERT(datetime, fecha_entrada + ' ' + ISNULL(hora_entrada, '00:00:00'), 103) AS entrada_at,\r\n        CASE\r\n            WHEN fecha_pesada IS NULL THEN NULL\r\n            ELSE CONVERT(datetime, fecha_pesada + ' ' + ISNULL(hora_pesada, '00:00:00'), 103)\r\n        END AS pesada_at,\r\n        ROW_NUMBER() OVER (\r\n            PARTITION BY UPPER(LTRIM(RTRIM(patente))), UPPER(LTRIM(RTRIM(chofer)))\r\n            ORDER BY CONVERT(datetime, fecha_entrada + ' ' + ISNULL(hora_entrada, '00:00:00'), 103) DESC\r\n        ) AS rn\r\n    FROM dbo.pr_ezi_movimientos\r\n    WHERE (estado IS NULL OR estado <> 'A')\r\n      AND numero_ingreso IS NOT NULL\r\n      AND fecha_salida IS NULL\r\n      AND fecha_entrada = CONVERT(varchar(10), GETDATE(), 103)\r\n)\r\nSELECT\r\n    COUNT(*)                                                        AS total_camiones,\r\n    SUM(CASE WHEN pesada_at IS NULL     THEN 1 ELSE 0 END)         AS esperando_balanza,\r\n    SUM(CASE WHEN pesada_at IS NOT NULL THEN 1 ELSE 0 END)         AS pesados_sin_salir,\r\n    ISNULL(SUM(neto_cana), 0)                                      AS toneladas_cana_pendiente,\r\n    ISNULL(AVG(DATEDIFF(MINUTE, entrada_at, GETDATE())), 0)        AS minutos_espera_promedio,\r\n    ISNULL(MAX(DATEDIFF(MINUTE, entrada_at, GETDATE())), 0)        AS minutos_espera_max\r\nFROM unicos\r\nWHERE rn = 1;",
