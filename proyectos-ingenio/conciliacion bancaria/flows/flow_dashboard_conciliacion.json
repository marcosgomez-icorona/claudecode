[
  {
    "id": "conc_dash_tab",
    "type": "tab",
    "label": "CONCILIACION - Dashboard",
    "disabled": false,
    "info": "=== DASHBOARD CONCILIACION BANCARIA ===\n\nENDPOINTS:\n  GET /api/conciliacion/resumen  → Resumen ejecutivo\n  GET /api/conciliacion/pendientes → Pendientes (PRIORITARIO)\n  GET /api/conciliacion/detalle  → Detalle completo\n  GET /conciliacion              → Dashboard HTML\n\nVERSION: 1.0.0"
  },
  {
    "id": "conc_dash_http_resumen",
    "type": "http in",
    "z": "conc_dash_tab",
    "name": "GET /api/conciliacion/resumen",
    "url": "/api/conciliacion/resumen",
    "method": "get",
    "upload": false,
    "swaggerDoc": "",
    "x": 130,
    "y": 100,
    "wires": [["conc_dash_read_resumen"]]
  },
  {
    "id": "conc_dash_read_resumen",
    "type": "GSheet",
    "z": "conc_dash_tab",
    "creds": "conc_dash_gauth",
    "method": "get",
    "sheet": "",
    "cells": "Resumen!A2:H",
    "flatten": false,
    "name": "Leer Resumen",
    "x": 370,
    "y": 100,
    "wires": [["conc_dash_fn_resumen"]]
  },
  {
    "id": "conc_dash_fn_resumen",
    "type": "function",
    "z": "conc_dash_tab",
    "name": "Formatear Resumen",
    "func": "var rows = msg.payload || [];\nvar data = [];\nfor (var i = 0; i < rows.length; i++) {\n  var r = rows[i];\n  if (!Array.isArray(r) || r.length < 8) continue;\n  data.push({\n    banco: r[0] || '', periodo: r[1] || '',\n    totalBanco: parseFloat(r[2]) || 0, totalCalipso: parseFloat(r[3]) || 0,\n    diferencia: parseFloat(r[4]) || 0, timing: parseFloat(r[5]) || 0,\n    semaforo: r[6] || 'SIN_DATOS', pendientes: parseInt(r[7]) || 0\n  });\n}\nmsg.payload = { success: true, data: data, _metadata: { timestamp: new Date().toISOString(), source: 'gsheet' } };\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 600,
    "y": 100,
    "wires": [["conc_dash_out_resumen"]]
  },
  {
    "id": "conc_dash_out_resumen",
    "type": "http response",
    "z": "conc_dash_tab",
    "name": "Responder Resumen",
    "statusCode": "",
    "headers": { "Content-Type": "application/json; charset=utf-8", "Access-Control-Allow-Origin": "*" },
    "x": 830,
    "y": 100,
    "wires": []
  },
  {
    "id": "conc_dash_http_pend",
    "type": "http in",
    "z": "conc_dash_tab",
    "name": "GET /api/conciliacion/pendientes",
    "url": "/api/conciliacion/pendientes",
    "method": "get",
    "upload": false,
    "swaggerDoc": "",
    "x": 130,
    "y": 180,
    "wires": [["conc_dash_read_pend"]]
  },
  {
    "id": "conc_dash_read_pend",
    "type": "GSheet",
    "z": "conc_dash_tab",
    "creds": "conc_dash_gauth",
    "method": "get",
    "sheet": "",
    "cells": "Pendientes!A2:H",
    "flatten": false,
    "name": "Leer Pendientes",
    "x": 370,
    "y": 180,
    "wires": [["conc_dash_fn_pend"]]
  },
  {
    "id": "conc_dash_fn_pend",
    "type": "function",
    "z": "conc_dash_tab",
    "name": "Formatear Pendientes",
    "func": "var rows = msg.payload || [];\nvar data = [];\nvar criticas = 0, altas = 0, medias = 0;\nfor (var i = 0; i < rows.length; i++) {\n  var r = rows[i];\n  if (!Array.isArray(r) || r.length < 8) continue;\n  var crit = r[6] || 'MEDIA';\n  if (crit === 'CRITICA') criticas++;\n  else if (crit === 'ALTA') altas++;\n  else medias++;\n  data.push({\n    banco: r[0] || '', fecha: r[1] || '', descripcion: r[2] || '',\n    importe: parseFloat(r[3]) || 0, tipo: r[4] || '',\n    origen: r[5] || '', criticidad: crit, observacion: r[7] || ''\n  });\n}\nmsg.payload = { success: true, data: data, criticas: criticas, altas: altas, medias: medias, total: data.length, _metadata: { timestamp: new Date().toISOString(), source: 'gsheet' } };\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 600,
    "y": 180,
    "wires": [["conc_dash_out_pend"]]
  },
  {
    "id": "conc_dash_out_pend",
    "type": "http response",
    "z": "conc_dash_tab",
    "name": "Responder Pendientes",
    "statusCode": "",
    "headers": { "Content-Type": "application/json; charset=utf-8", "Access-Control-Allow-Origin": "*" },
    "x": 830,
    "y": 180,
    "wires": []
  },
  {
    "id": "conc_dash_http_detalle",
    "type": "http in",
    "z": "conc_dash_tab",
    "name": "GET /api/conciliacion/detalle",
    "url": "/api/conciliacion/detalle",
    "method": "get",
    "upload": false,
    "swaggerDoc": "",
    "x": 130,
    "y": 260,
    "wires": [["conc_dash_read_detalle"]]
  },
  {
    "id": "conc_dash_read_detalle",
    "type": "GSheet",
    "z": "conc_dash_tab",
    "creds": "conc_dash_gauth",
    "method": "get",
    "sheet": "",
    "cells": "Conciliacion!A2:H",
    "flatten": false,
    "name": "Leer Conciliacion",
    "x": 370,
    "y": 260,
    "wires": [["conc_dash_fn_detalle"]]
  },
  {
    "id": "conc_dash_fn_detalle",
    "type": "function",
    "z": "conc_dash_tab",
    "name": "Formatear Detalle",
    "func": "var rows = msg.payload || [];\nvar data = [];\nvar conciliados = 0, soloBanco = 0, soloCalipso = 0, timing = 0;\nfor (var i = 0; i < rows.length; i++) {\n  var r = rows[i];\n  if (!Array.isArray(r) || r.length < 8) continue;\n  var est = r[6] || 'SOLO_BANCO';\n  if (est === 'CONCILIADO') conciliados++;\n  else if (est === 'SOLO_BANCO') soloBanco++;\n  else if (est === 'SOLO_CALIPSO') soloCalipso++;\n  else if (est === 'TIMING') timing++;\n  data.push({\n    fecha: r[0] || '', tipo: r[1] || '', descripcion: r[2] || '',\n    banco: parseFloat(r[3]) || 0, calipso: parseFloat(r[4]) || 0,\n    dif: parseFloat(r[5]) || 0, estado: est, criticidad: r[7] || 'OK'\n  });\n}\nmsg.payload = { success: true, data: data, conciliados: conciliados, soloBanco: soloBanco, soloCalipso: soloCalipso, timing: timing, total: data.length, _metadata: { timestamp: new Date().toISOString(), source: 'gsheet' } };\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 600,
    "y": 260,
    "wires": [["conc_dash_out_detalle"]]
  },
  {
    "id": "conc_dash_out_detalle",
    "type": "http response",
    "z": "conc_dash_tab",
    "name": "Responder Detalle",
    "statusCode": "",
    "headers": { "Content-Type": "application/json; charset=utf-8", "Access-Control-Allow-Origin": "*" },
    "x": 830,
    "y": 260,
    "wires": []
  },
  {
    "id": "conc_dash_http_html",
    "type": "http in",
    "z": "conc_dash_tab",
    "name": "GET /conciliacion",
    "url": "/conciliacion",
    "method": "get",
    "upload": false,
    "swaggerDoc": "",
    "x": 130,
    "y": 360,
    "wires": [["conc_dash_tmpl"]]
  },
  {
    "id": "conc_dash_tmpl",
    "type": "template",
    "z": "conc_dash_tab",
    "name": "Dashboard HTML",
    "field": "payload",
    "fieldType": "msg",
    "format": "html",
    "syntax": "mustache",
    "template": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Conciliación Bancaria | Bioenergía La Corona</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n  <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\n  <script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js\"></script>\n  <style>\n    :root {\n      --corona-green: #1D9E75; --corona-green-dark: #0F6E56; --corona-green-light: #E1F5EE;\n      --accent-blue: #185FA5; --accent-red: #A32D2D; --accent-red-light: #FCEBEB;\n      --accent-amber: #BA7517; --accent-amber-light: #FAEEDA;\n      --surface: #FFFFFF; --surface-2: #F7F8FA; --surface-3: #F0F2F5;\n      --text-primary: #1A1D23; --text-secondary: #5A6170; --text-muted: #9BA3AF;\n      --border: rgba(0,0,0,0.08); --border-strong: rgba(0,0,0,0.15);\n      --font-sans: 'Inter', system-ui, sans-serif; --font-mono: 'JetBrains Mono', monospace;\n      --radius: 10px; --radius-lg: 14px;\n    }\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body { font-family: var(--font-sans); background: var(--surface-3); color: var(--text-primary); font-size: 14px; }\n    .app { display: flex; min-height: 100vh; }\n    .sidebar { width: 240px; background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; }\n    .sidebar-brand { padding: 20px; border-bottom: 1px solid var(--border); }\n    .brand-name { font-weight: 700; font-size: 13px; display: flex; align-items: center; gap: 10px; }\n    .brand-logo { width: 32px; height: 32px; background: var(--corona-green); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 14px; }\n    .brand-sub { font-size: 11px; color: var(--text-muted); margin-left: 42px; }\n    .nav-section { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; padding: 16px 20px 6px; letter-spacing: .8px; }\n    .nav-item { display: flex; align-items: center; gap: 10px; padding: 8px 20px; color: var(--text-secondary); text-decoration: none; font-size: 13px; border-left: 2px solid transparent; cursor: pointer; }\n    .nav-item:hover { color: var(--corona-green-dark); background: var(--corona-green-light); }\n    .nav-item.active { color: var(--corona-green-dark); background: var(--corona-green-light); border-left-color: var(--corona-green); font-weight: 500; }\n    .sidebar-footer { margin-top: auto; padding: 16px 20px; border-top: 1px solid var(--border); font-size: 11px; color: var(--text-muted); }\n    .main { margin-left: 240px; flex: 1; display: flex; flex-direction: column; }\n    .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 12px 28px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }\n    .topbar h1 { font-size: 16px; font-weight: 600; }\n    .topbar p { font-size: 12px; color: var(--text-muted); }\n    .badge-period { background: var(--corona-green-light); color: var(--corona-green-dark); font-size: 11px; font-weight: 500; padding: 4px 10px; border-radius: 20px; font-family: var(--font-mono); }\n    .btn { padding: 7px 14px; border-radius: 8px; font-size: 12px; font-weight: 500; cursor: pointer; border: none; }\n    .btn-primary { background: var(--corona-green); color: #fff; }\n    .btn-primary:hover { background: var(--corona-green-dark); }\n    .content { padding: 24px 28px; flex:1; }\n    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 14px; margin-bottom: 24px; }\n    .kpi-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 18px 20px; position: relative; overflow: hidden; }\n    .kpi-card::before { content: ''; position: absolute; top:0; left:0; right:0; height:3px; }\n    .kpi-card.green::before { background: var(--corona-green); }\n    .kpi-card.amber::before { background: var(--accent-amber); }\n    .kpi-card.red::before { background: var(--accent-red); }\n    .kpi-card.blue::before { background: var(--accent-blue); }\n    .kpi-label { font-size: 11px; font-weight: 500; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px; }\n    .kpi-value { font-size: 24px; font-weight: 700; line-height: 1; margin-bottom: 6px; }\n    .kpi-value.mono { font-family: var(--font-mono); font-size: 17px; }\n    .kpi-delta { font-size: 11px; color: var(--text-muted); }\n    .panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); margin-bottom: 20px; overflow: hidden; }\n    .panel-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid var(--border); }\n    .panel-title { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }\n    .panel-title .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--corona-green); }\n    .panel-body { overflow-x: auto; }\n    table { width: 100%; border-collapse: collapse; font-size: 13px; }\n    thead th { background: var(--surface-2); color: var(--text-muted); font-size: 10px; font-weight: 600; text-transform: uppercase; padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }\n    thead th.num { text-align: right; }\n    tbody tr { border-bottom: 1px solid var(--border); }\n    tbody tr:hover { background: var(--surface-2); }\n    tbody td { padding: 10px 14px; vertical-align: middle; }\n    tbody td.num { text-align: right; font-family: var(--font-mono); font-size: 12px; }\n    tbody td.code { font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary); }\n    .badge-crit { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: var(--accent-red-light); color: var(--accent-red); }\n    .badge-warn { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: var(--accent-amber-light); color: var(--accent-amber); }\n    .badge-ok { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; font-weight: 600; padding: 3px 10px; border-radius: 20px; background: var(--corona-green-light); color: var(--corona-green-dark); }\n    .badge-crit::before { content: '●'; font-size: 8px; }\n    .badge-warn::before { content: '●'; font-size: 8px; }\n    .badge-ok::before { content: '●'; font-size: 8px; }\n    .pendiente-row-critica { background: #FFF5F5; border-left: 3px solid var(--accent-red); }\n    .pendiente-row-alta { background: #FFFBF0; border-left: 3px solid var(--accent-amber); }\n    .semaforo { display: inline-flex; align-items: center; gap: 6px; font-weight: 600; font-size: 13px; }\n    .semaforo-dot { width: 12px; height: 12px; border-radius: 50%; }\n    .empty { text-align: center; padding: 48px 20px; color: var(--text-muted); }\n    .empty h3 { font-size: 14px; font-weight: 500; color: var(--text-secondary); margin-bottom: 6px; }\n    .empty p { font-size: 12px; }\n    .chart-wrap { padding: 20px; height: 260px; }\n    .section-view { display: none; }\n    .section-view.active { display: block; }\n    @media print { .sidebar { display: none; } .main { margin-left: 0; } }\n  </style>\n</head>\n<body>\n<div class=\"app\">\n  <aside class=\"sidebar\">\n    <div class=\"sidebar-brand\">\n      <div class=\"brand-name\"><span class=\"brand-logo\">BLC</span>Bioenergía La Corona</div>\n      <div class=\"brand-sub\">Tesorería · Conciliación</div>\n    </div>\n    <div class=\"nav-section\">Conciliación</div>\n    <a class=\"nav-item active\" onclick=\"showSection('resumen')\">📊 Resumen Ejecutivo</a>\n    <a class=\"nav-item\" onclick=\"showSection('pendientes')\">⚠️ Pendientes</a>\n    <a class=\"nav-item\" onclick=\"showSection('detalle')\">🏦 Detalle Galicia</a>\n    <div class=\"nav-section\">Reportes</div>\n    <a class=\"nav-item\" onclick=\"showSection('gastos')\">💰 Gastos Bancarios</a>\n    <div class=\"nav-section\">Visualización</div>\n    <a class=\"nav-item\" onclick=\"showSection('graficos')\">📈 Gráficos</a>\n    <div class=\"sidebar-footer\">\n      <div>Conciliación Bancaria v1.0</div>\n      <div style=\"margin-top:4px;\">Bioenergía La Corona S.A.</div>\n    </div>\n  </aside>\n  <div class=\"main\">\n    <div class=\"topbar\">\n      <div>\n        <h1 id=\"section-title\">Resumen Ejecutivo</h1>\n        <p id=\"section-desc\">Conciliación Bancaria — Febrero 2026 | Banco Galicia</p>\n      </div>\n      <div class=\"topbar-actions\">\n        <span class=\"badge-period\" id=\"period-badge\">Feb 2026</span>\n        <button class=\"btn btn-primary\" onclick=\"refreshAll()\">🔄 Actualizar</button>\n      </div>\n    </div>\n    <div class=\"content\">\n      <div id=\"section-resumen\" class=\"section-view active\">\n        <div class=\"kpi-grid\" id=\"resumen-kpis\"></div>\n        <div class=\"panel\">\n          <div class=\"panel-header\"><div class=\"panel-title\"><span class=\"dot\"></span>Resumen por Banco</div></div>\n          <div class=\"panel-body\"><table><thead><tr>\n            <th>Banco</th><th>Período</th><th class=\"num\">Total Banco</th><th class=\"num\">Total Calipso</th><th class=\"num\">Diferencia</th><th>Estado</th><th class=\"num\">Pendientes</th>\n          </tr></thead><tbody id=\"resumen-body\"><tr><td colspan=\"7\"><div class=\"empty\"><h3>Cargando...</h3></div></td></tr></tbody></table></div>\n        </div>\n      </div>\n      <div id=\"section-pendientes\" class=\"section-view\">\n        <div class=\"kpi-grid\" id=\"pendientes-kpis\"></div>\n        <div class=\"panel\">\n          <div class=\"panel-header\">\n            <div class=\"panel-title\"><span class=\"dot\" style=\"background:var(--accent-red)\"></span>Pendientes de Conciliación</div>\n            <div class=\"panel-tools\">\n              <select class=\"panel-tool-btn\" id=\"filter-pend-crit\" onchange=\"renderPendientes()\" style=\"padding:4px 8px;border-radius:6px;\">\n                <option value=\"\">Todas las criticidades</option>\n                <option value=\"CRITICA\">🔴 Críticas</option>\n                <option value=\"ALTA\">🟠 Altas</option>\n                <option value=\"MEDIA\">🟡 Medias</option>\n              </select>\n            </div>\n          </div>\n          <div class=\"panel-body\"><table><thead><tr>\n            <th>Banco</th><th>Fecha</th><th>Descripción</th><th>Origen</th><th class=\"num\">Importe</th><th>Tipo</th><th>Criticidad</th><th>Observación</th>\n          </tr></thead><tbody id=\"pendientes-body\"><tr><td colspan=\"8\"><div class=\"empty\"><h3>Cargando...</h3></div></td></tr></tbody></table></div>\n        </div>\n      </div>\n      <div id=\"section-detalle\" class=\"section-view\">\n        <div class=\"kpi-grid\" id=\"detalle-kpis\"></div>\n        <div class=\"panel\">\n          <div class=\"panel-header\"><div class=\"panel-title\"><span class=\"dot\" style=\"background:var(--accent-blue)\"></span>Detalle Galicia — Febrero 2026</div></div>\n          <div class=\"panel-body\"><table><thead><tr>\n            <th>Fecha</th><th>Tipo</th><th>Descripción</th><th class=\"num\">Banco</th><th class=\"num\">Calipso</th><th class=\"num\">Dif</th><th>Estado</th>\n          </tr></thead><tbody id=\"detalle-body\"><tr><td colspan=\"7\"><div class=\"empty\"><h3>Cargando...</h3></div></td></tr></tbody></table></div>\n        </div>\n      </div>\n      <div id=\"section-gastos\" class=\"section-view\">\n        <div class=\"panel\">\n          <div class=\"panel-header\"><div class=\"panel-title\"><span class=\"dot\" style=\"background:var(--accent-amber)\"></span>Gastos Bancarios</div></div>\n          <div class=\"panel-body\"><table><thead><tr>\n            <th>Fecha</th><th>Descripción</th><th>Tipo</th><th class=\"num\">Importe</th><th>Estado</th>\n          </tr></thead><tbody id=\"gastos-body\"><tr><td colspan=\"5\"><div class=\"empty\"><h3>Cargando...</h3></div></td></tr></tbody></table></div>\n        </div>\n      </div>\n      <div id=\"section-graficos\" class=\"section-view\">\n        <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:16px;\">\n          <div class=\"panel\">\n            <div class=\"panel-header\"><div class=\"panel-title\"><span class=\"dot\"></span>Distribución de Estados</div></div>\n            <div class=\"chart-wrap\"><canvas id=\"chartEstados\"></canvas></div>\n          </div>\n          <div class=\"panel\">\n            <div class=\"panel-header\"><div class=\"panel-title\"><span class=\"dot\" style=\"background:var(--accent-red)\"></span>Pendientes por Criticidad</div></div>\n            <div class=\"chart-wrap\"><canvas id=\"chartCriticidad\"></canvas></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n<script>\nconst API = window.location.origin;\nlet STATE = { resumen: null, pendientes: null, detalle: null };\nlet CHARTS = {};\n\nfunction fmt$(n) { if (n == null || isNaN(n)) return '—'; return '$ ' + Number(n).toLocaleString('es-AR', { maximumFractionDigits: 0 }); }\nfunction fmtFecha(s) { if (!s || s.length < 8) return s || '—'; return s.substring(6,8) + '/' + s.substring(4,6) + '/' + s.substring(0,4); }\n\nasync function refreshAll() {\n  showSection(STATE._current || 'resumen');\n}\n\nfunction showSection(id) {\n  document.querySelectorAll('.section-view').forEach(e => e.classList.remove('active'));\n  document.querySelectorAll('.nav-item').forEach(e => e.classList.remove('active'));\n  var t = document.getElementById('section-' + id);\n  if (t) t.classList.add('active');\n  document.querySelectorAll('.nav-item').forEach(e => { if (e.getAttribute('onclick') && e.getAttribute('onclick').includes(\"'\" + id + \"'\")) e.classList.add('active'); });\n  STATE._current = id;\n  var titles = { resumen: ['Resumen Ejecutivo', 'Conciliación Bancaria — Febrero 2026 | Banco Galicia'], pendientes: ['Pendientes de Conciliación', 'Ítems sin conciliar — Requieren acción'], detalle: ['Detalle Galicia', 'Cruce banco vs Calipso — Febrero 2026'], gastos: ['Gastos Bancarios', 'Gastos e impuestos detectados en el extracto'], graficos: ['Gráficos', 'Visualización de datos de conciliación'] };\n  var tInfo = titles[id] || [id, ''];\n  document.getElementById('section-title').textContent = tInfo[0];\n  document.getElementById('section-desc').textContent = tInfo[1];\n  if (id === 'resumen') cargarResumen();\n  else if (id === 'pendientes') cargarPendientes();\n  else if (id === 'detalle') cargarDetalle();\n  else if (id === 'gastos') cargarGastos();\n  else if (id === 'graficos') cargarGraficos();\n}\n\nasync function cargarResumen() {\n  try {\n    var r = await fetch(API + '/api/conciliacion/resumen');\n    var d = await r.json();\n    STATE.resumen = d;\n    var row = (d.data||[])[0] || {};\n    var semaforo = row.semaforo || 'SIN_DATOS';\n    var semaColor = semaforo === 'VERDE' ? 'var(--corona-green)' : semaforo === 'AMARILLO' ? 'var(--accent-amber)' : 'var(--accent-red)';\n    var semaText = semaforo === 'VERDE' ? 'CUADRADO' : semaforo === 'AMARILLO' ? 'TIMING' : 'PENDIENTE';\n    document.getElementById('resumen-kpis').innerHTML = `\n      <div class=\"kpi-card green\"><div class=\"kpi-label\">Total Banco</div><div class=\"kpi-value mono\">${fmt$(row.totalBanco)}</div><div class=\"kpi-delta\">Extracto Feb 2026</div></div>\n      <div class=\"kpi-card blue\"><div class=\"kpi-label\">Total Calipso</div><div class=\"kpi-value mono\">${fmt$(row.totalCalipso)}</div><div class=\"kpi-delta\">Depurado (sin reversiones)</div></div>\n      <div class=\"kpi-card ${row.diferencia === 0 ? 'green' : 'red'}\"><div class=\"kpi-label\">Diferencia</div><div class=\"kpi-value mono\">${fmt$(row.diferencia)}</div><div class=\"kpi-delta\">${row.diferencia === 0 ? '✅ Cuadrado' : '⚠ Requiere revisión'}</div></div>\n      <div class=\"kpi-card ${row.pendientes > 0 ? 'red' : 'green'}\"><div class=\"kpi-label\">Pendientes</div><div class=\"kpi-value\">${row.pendientes || 0}</div><div class=\"kpi-delta\">Ítems sin conciliar</div></div>\n      <div class=\"kpi-card ${semaforo === 'VERDE' ? 'green' : semaforo === 'AMARILLO' ? 'amber' : 'red'}\"><div class=\"kpi-label\">Estado</div><div class=\"kpi-value\" style=\"font-size:18px;\"><span class=\"semaforo\"><span class=\"semaforo-dot\" style=\"background:${semaColor}\"></span>${semaText}</span></div><div class=\"kpi-delta\">${semaforo === 'VERDE' ? '✅ Conciliación exitosa' : '⚠ Acción requerida'}</div></div>`;\n    document.getElementById('resumen-body').innerHTML = (d.data||[]).map(r => `<tr>\n      <td><strong>${r.banco}</strong></td><td class=\"code\">${r.periodo}</td>\n      <td class=\"num\">${fmt$(r.totalBanco)}</td><td class=\"num\">${fmt$(r.totalCalipso)}</td>\n      <td class=\"num\"><strong style=\"color:${r.diferencia===0?'var(--corona-green-dark)':'var(--accent-red)'}\">${fmt$(r.diferencia)}</strong></td>\n      <td><span class=\"badge-${r.semaforo==='VERDE'?'ok':r.semaforo==='AMARILLO'?'warn':'crit'}\">${r.semaforo}</span></td>\n      <td class=\"num\">${r.pendientes}</td></tr>`).join('');\n  } catch(e) { console.error(e); }\n}\n\nasync function cargarPendientes() {\n  try {\n    var r = await fetch(API + '/api/conciliacion/pendientes');\n    var d = await r.json();\n    STATE.pendientes = d;\n    document.getElementById('pendientes-kpis').innerHTML = `\n      <div class=\"kpi-card red\"><div class=\"kpi-label\">🔴 Críticas</div><div class=\"kpi-value\">${d.criticas||0}</div><div class=\"kpi-delta\">> $10M o gastos sin registrar</div></div>\n      <div class=\"kpi-card amber\"><div class=\"kpi-label\">🟠 Altas</div><div class=\"kpi-value\">${d.altas||0}</div><div class=\"kpi-delta\">> $1M</div></div>\n      <div class=\"kpi-card blue\"><div class=\"kpi-label\">🟡 Medias</div><div class=\"kpi-value\">${d.medias||0}</div><div class=\"kpi-delta\">Resto de pendientes</div></div>\n      <div class=\"kpi-card ${d.total > 0 ? 'red' : 'green'}\"><div class=\"kpi-label\">Total Pendientes</div><div class=\"kpi-value\">${d.total||0}</div><div class=\"kpi-delta\">${d.total === 0 ? '✅ Todo conciliado' : '⚠ Requieren acción'}</div></div>`;\n    renderPendientes();\n  } catch(e) { console.error(e); }\n}\n\nfunction renderPendientes() {\n  var d = STATE.pendientes;\n  if (!d) return;\n  var filtro = document.getElementById('filter-pend-crit')?.value || '';\n  var data = filtro ? (d.data||[]).filter(r => r.criticidad === filtro) : (d.data||[]);\n  document.getElementById('pendientes-body').innerHTML = data.length ? data.map(r => {\n    var rowClass = r.criticidad === 'CRITICA' ? 'pendiente-row-critica' : r.criticidad === 'ALTA' ? 'pendiente-row-alta' : '';\n    var badgeClass = r.criticidad === 'CRITICA' ? 'badge-crit' : r.criticidad === 'ALTA' ? 'badge-warn' : 'badge-ok';\n    return `<tr class=\"${rowClass}\">\n      <td><strong>${r.banco}</strong></td><td class=\"code\">${fmtFecha(r.fecha)}</td>\n      <td>${r.descripcion}</td><td>${r.origen}</td>\n      <td class=\"num\"><strong>${fmt$(r.importe)}</strong></td><td>${r.tipo}</td>\n      <td><span class=\"${badgeClass}\">${r.criticidad}</span></td><td style=\"font-size:11px;color:var(--text-secondary);\">${r.observacion||''}</td>\n    </tr>`;\n  }).join('') : '<tr><td colspan=\"8\"><div class=\"empty\"><h3>Sin pendientes</h3><p>Todos los movimientos están conciliados ✅</p></div></td></tr>';\n}\n\nasync function cargarDetalle() {\n  try {\n    var r = await fetch(API + '/api/conciliacion/detalle');\n    var d = await r.json();\n    STATE.detalle = d;\n    document.getElementById('detalle-kpis').innerHTML = `\n      <div class=\"kpi-card green\"><div class=\"kpi-label\">Conciliados</div><div class=\"kpi-value\">${d.conciliados||0}</div></div>\n      <div class=\"kpi-card red\"><div class=\"kpi-label\">Solo Banco</div><div class=\"kpi-value\">${d.soloBanco||0}</div></div>\n      <div class=\"kpi-card amber\"><div class=\"kpi-label\">Solo Calipso</div><div class=\"kpi-value\">${d.soloCalipso||0}</div></div>\n      <div class=\"kpi-card blue\"><div class=\"kpi-label\">Timing</div><div class=\"kpi-value\">${d.timing||0}</div></div>`;\n    document.getElementById('detalle-body').innerHTML = (d.data||[]).slice(0, 500).map(r => `<tr>\n      <td class=\"code\">${fmtFecha(r.fecha)}</td><td>${r.tipo}</td><td>${r.descripcion}</td>\n      <td class=\"num\">${r.banco ? fmt$(r.banco) : '—'}</td><td class=\"num\">${r.calipso ? fmt$(r.calipso) : '—'}</td>\n      <td class=\"num\"><strong style=\"color:${r.dif > 100 ? 'var(--accent-red)' : 'var(--text-muted)'}\">${fmt$(r.dif)}</strong></td>\n      <td><span class=\"badge-${r.estado==='CONCILIADO'?'ok':r.estado==='TIMING'?'warn':'crit'}\">${r.estado}</span></td>\n    </tr>`).join('');\n  } catch(e) { console.error(e); }\n}\n\nasync function cargarGastos() {\n  try {\n    var r = await fetch(API + '/api/conciliacion/detalle');\n    var d = await r.json();\n    var gastos = (d.data||[]).filter(r => (r.tipo||'').toLowerCase().indexOf('gasto') >= 0 || (r.tipo||'').toLowerCase().indexOf('impuesto') >= 0 || (r.descripcion||'').toLowerCase().indexOf('iva') >= 0 || (r.descripcion||'').toLowerCase().indexOf('iibb') >= 0 || (r.descripcion||'').toLowerCase().indexOf('comision') >= 0);\n    document.getElementById('gastos-body').innerHTML = gastos.length ? gastos.map(r => `<tr>\n      <td class=\"code\">${fmtFecha(r.fecha)}</td><td>${r.descripcion}</td><td>${r.tipo}</td>\n      <td class=\"num\"><strong>${fmt$(Math.abs(r.banco||r.calipso||0))}</strong></td>\n      <td><span class=\"badge-${r.estado==='CONCILIADO'?'ok':'crit'}\">${r.estado}</span></td>\n    </tr>`).join('') : '<tr><td colspan=\"5\"><div class=\"empty\"><h3>Sin gastos detectados</h3></div></td></tr>';\n  } catch(e) { console.error(e); }\n}\n\nasync function cargarGraficos() {\n  if (!STATE.detalle) {\n    var r = await fetch(API + '/api/conciliacion/detalle');\n    STATE.detalle = await r.json();\n  }\n  var d = STATE.detalle;\n  if (!d) return;\n  // Chart 1: Estados\n  if (CHARTS.estados) CHARTS.estados.destroy();\n  var ctx1 = document.getElementById('chartEstados').getContext('2d');\n  CHARTS.estados = new Chart(ctx1, { type: 'doughnut', data: { labels: ['Conciliado','Solo Banco','Solo Calipso','Timing'], datasets: [{ data: [d.conciliados||0, d.soloBanco||0, d.soloCalipso||0, d.timing||0], backgroundColor: ['#1D9E75','#A32D2D','#BA7517','#185FA5'], borderWidth: 2, borderColor: '#fff' }] }, options: { responsive: true, maintainAspectRatio: false, cutout: '60%', plugins: { legend: { position: 'bottom', labels: { font: { size: 10 }, boxWidth: 10 } } } } });\n  // Chart 2: Criticidad\n  if (!STATE.pendientes) {\n    var r2 = await fetch(API + '/api/conciliacion/pendientes');\n    STATE.pendientes = await r2.json();\n  }\n  var pd = STATE.pendientes || {};\n  if (CHARTS.criticidad) CHARTS.criticidad.destroy();\n  var ctx2 = document.getElementById('chartCriticidad').getContext('2d');\n  CHARTS.criticidad = new Chart(ctx2, { type: 'bar', data: { labels: ['Críticas','Altas','Medias'], datasets: [{ data: [pd.criticas||0, pd.altas||0, pd.medias||0], backgroundColor: ['#A32D2D','#BA7517','#185FA5'], borderRadius: 4 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } } });\n}\n\ndocument.addEventListener('DOMContentLoaded', function() { showSection('resumen'); });\n</script>\n</body>\n</html>",
    "x": 370,
    "y": 360,
    "wires": [["conc_dash_out_html"]]
  },
