        "z": "5519da82a1fff81f",
        "name": "Query UPDATE",
        "func": "msg._req = msg.req;\nmsg._res = msg.res;\nconst b = msg.req.body;\nmsg.topic = `UPDATE staging_facturas SET\n    tipo_operacion    = ?,\n    proveedor_nombre  = ?,\n    proveedor_cuit    = ?,\n    letra             = ?,\n    numerodocumento   = ?,\n    fecha_emision     = ?,\n    fecha_vencimiento = ?,\n    cae               = ?,\n    fecha_vto_cae     = ?,\n    referencia        = ?,\n    centrocostos_nombre = ?,\n    neto              = ?,\n    iva_21            = ?,\n    iva_105           = ?,\n    percepciones      = ?,\n    otros_impuestos   = ?,\n    total             = ?,\n    cotizacion        = ?,\n    items_json        = ?\nWHERE id = ? AND estado_proceso = 'PENDIENTE'`;\nmsg.payload = [\n    b.tipo_operacion    || 'FACTURA_COMPRA',\n    b.proveedor_nombre  || null,\n    b.proveedor_cuit    || null,\n    b.letra             || 'A',\n    b.numerodocumento   || null,\n    b.fecha_emision     || null,\n    b.fecha_vencimiento || null,\n    b.cae               || null,\n    b.fecha_vto_cae     || null,\n    b.referencia        || null,\n    b.centrocostos_nombre || null,\n    parseFloat(b.neto)   || 0,\n    parseFloat(b.iva_21) || 0,\n    parseFloat(b.iva_105)|| 0,\n    parseFloat(b.percepciones) || 0,\n    parseFloat(b.otros_impuestos) || 0,\n    parseFloat(b.total)  || 0,\n    parseFloat(b.cotizacion) || 1,\n    b.items_json         || null,\n    msg.req.params.id\n];\nreturn msg;\n",
        "outputs": 1,
        "x": 390,
        "y": 300,
        "wires": [
