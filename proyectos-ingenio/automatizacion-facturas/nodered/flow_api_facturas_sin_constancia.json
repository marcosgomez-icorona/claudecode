        "name": "Query pendientes",
        "func": "msg._req = msg.req;\nmsg._res = msg.res;\nmsg.topic = `SELECT id, tipo_operacion, estado_proceso, fecha_carga,\n    numerodocumento, letra, fecha_emision, fecha_vencimiento,\n    proveedor_cuit, proveedor_nombre, proveedor_codigo,\n    neto, iva_21, iva_105, total, moneda_id, cotizacion,\n    cae, referencia, pdf_filename, email_origen\nFROM staging_facturas\nWHERE estado_proceso = 'PENDIENTE'\nORDER BY fecha_carga ASC`;\nmsg.payload = [];\nreturn msg;\n",
