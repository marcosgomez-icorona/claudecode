        "func": "msg._req = msg.req;\nmsg._res = msg.res;\nmsg.payload = `SELECT\\n    ESTADO_PROCESO   AS estado,\\n    COUNT(*)         AS cantidad,\\n    SUM(TOTAL)       AS total_acumulado,\\n    MIN(FECHA_CARGA) AS mas_antigua,\\n    MAX(FECHA_CARGA) AS mas_reciente\\nFROM UD_EZI_STAGING_FACTURAS\\nGROUP BY ESTADO_PROCESO\\nORDER BY\\n  CASE ESTADO_PROCESO\\n    WHEN 'APROBADO' THEN 1 WHEN 'PENDIENTE' THEN 2\\n    WHEN 'EN_REVISION' THEN 3 WHEN 'PROCESADO' THEN 4\\n    WHEN 'RECHAZADO' THEN 5 WHEN 'ERROR' THEN 6 ELSE 7 END`;\\nreturn msg;",
