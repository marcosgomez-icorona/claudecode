        "func": "msg._req = msg.req;\nmsg._res = msg.res;\nconst b = msg.req.body || {};\\nconst operador = b.operador || 'pdietrich';\\nconst motivo = (b.motivo || 'Rechazado').replace(/'/g, \"''\");\\nconst id = msg.req.params.id.replace(/'/g, \"''\");\\nconst ts = CONVERT(varchar(8), GETDATE(), 112) +\\n           REPLACE(REPLACE(REPLACE(CONVERT(varchar(12), GETDATE(), 114),':',''),'.',''),' ','');\\nmsg.payload = `UPDATE UD_EZI_STAGING_FACTURAS\\nSET ESTADO_PROCESO    = 'RECHAZADO',\\n    FECHA_APROBACION  = '${ts}',\\n    APROBADO_POR      = '${operador.replace(/'/g, \"''\")}' ,\\n    ERROR_DETALLE     = '${motivo}'\\nWHERE ID = '${id}'\\n  AND ESTADO_PROCESO IN ('PENDIENTE', 'EN_REVISION')`;\\nreturn msg;",
