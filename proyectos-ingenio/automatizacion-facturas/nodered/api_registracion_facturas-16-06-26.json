        "name": "Query check duplicado",
        "func": "msg._req = msg.req;\nmsg._res = msg.res;\nconst hash = (msg.req.query.hash || '').replace(/[^a-fA-F0-9]/g, '');\nconst doc  = (msg.req.query.doc  || '').replace(/[^0-9\\-]/g, '');\nconst cuit = (msg.req.query.cuit || '').replace(/[^0-9]/g, '');\nlet where = '1=0';\nif (hash) where = `PDF_HASH = '${hash}'`;\nelse if (doc && cuit) where = `NUMERODOCUMENTO = '${doc}' AND PROVEEDOR_CUIT = '${cuit}'`;\nmsg.payload = `SELECT TOP 1 ID FROM UD_EZI_STAGING_FACTURAS WHERE ${where}`;\nreturn msg;",
