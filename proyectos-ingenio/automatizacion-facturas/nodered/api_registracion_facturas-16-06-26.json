        "func": "msg._req = msg.req;\nmsg._res = msg.res;\nconst q = (msg.req.query.q || '').replace(/[^a-zA-Z0-9 ]/g, '');\nif (!q || q.length < 2) { msg.payload = JSON.stringify([]); return msg; }\nmsg.payload = `SELECT TOP 20 ID, CODIGO, DENOMINACION AS nombre, CUIT AS cuit\\nFROM PROVEEDOR\\nWHERE ACTIVESTATUS = 0\\n  AND (DENOMINACION LIKE '%${q}%' OR CUIT LIKE '%${q}%' OR CODIGO LIKE '%${q}%')\\nORDER BY DENOMINACION`;\\nreturn msg;",
