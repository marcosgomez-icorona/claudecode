        "func": "msg._req = msg.req;\nmsg._res = msg.res;\nconst cuit = (msg.req.params.cuit || '').replace(/[^0-9]/g, '');\nif (!cuit) {\n  msg.statusCode = 400;\n  msg.headers = {'Content-Type':'application/json','Access-Control-Allow-Origin':'*'};\n  msg.payload = JSON.stringify({ error: 'CUIT requerido' });\n  return [null, msg];\n}\nmsg.payload = `SELECT\\n    oc.ID AS id,\\n    oc.NUMERODOCUMENTO AS nro,\\n    CONVERT(varchar, oc.FECHAINGRESO, 112) AS fecha,\\n    oc.TOTAL AS total,\\n    oc.ESTADO AS estado,\\n    CASE WHEN EXISTS (SELECT 1 FROM TRFACTURACOMPRA fc WHERE fc.DETALLE = oc.NUMERODOCUMENTO) THEN 1 ELSE 0 END AS facturada\\nFROM TRORDENCOMPRA oc\\nJOIN PROVEEDOR p ON p.CODIGO = oc.CODIGODESTINATARIO\\nWHERE p.CUIT = '${cuit}' AND oc.ESTADO IN ('A','P','C')\\nORDER BY oc.FECHAINGRESO DESC`;\\nreturn [msg, null];",
