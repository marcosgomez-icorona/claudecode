        "func": "msg._res = msg.res;\nconst oc = (msg.req.query.oc || '').replace(/[^0-9A-Za-z\\-]/g, '');\nif (!oc) {\n  msg.statusCode = 400;\n  msg.headers = {'Content-Type':'application/json','Access-Control-Allow-Origin':'*'};\n  msg.payload = JSON.stringify({ ok: false, error: 'Falta parámetro oc' });\n  return [null, msg];\n}\nmsg.payload = `SELECT\n    enc.CONSTANCIA          AS nro_constancia,\n    CAST(enc.ID AS varchar(36)) AS id_constancia,\n    enc.FECHAACTUAL,\n    enc.DETALLE             AS detalle_interno,\n    enc.subtotal_doc,\n    enc.totalConstancia,\n    enc.monConstancia,\n    enc.nom_proveedor,\n    (SELECT TOP 1 ISNULL(d.NOM_PRODUCTO,'') + CASE WHEN ISNULL(d.MEMO,'') <> '' THEN ' — ' + d.MEMO ELSE '' END\n     FROM V_EZI_PROV_CONST_SC_DET d\n     WHERE d.constancia = enc.CONSTANCIA\n     ORDER BY d.NUMEROITEM) AS descripcion,\n    (SELECT TOP 1 cf.NUMEROFAC\n     FROM V_EZI_CONSTANCIA_FACTURA cf\n     WHERE cf.ID_CONST = enc.ID) AS factura_existente,\n    (SELECT TOP 1 cf.IMPORTEFACT\n     FROM V_EZI_CONSTANCIA_FACTURA cf\n     WHERE cf.ID_CONST = enc.ID) AS importe_factura_existente\nFROM V_EZI_PROV_CONST_SC_ENC enc\nWHERE enc.numeroOC = '${oc}'\nORDER BY enc.FECHAACTUAL DESC`;\nreturn [msg, null];\n",
