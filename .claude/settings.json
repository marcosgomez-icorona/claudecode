{
  "mcpServers": {
    "memory": {
      "command": "mcp-server-memory"
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/soporte/.claude/hooks/pre-message.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/soporte/.claude/hooks/post-message.sh"
          }
        ]
      }
    ]
  }
}
